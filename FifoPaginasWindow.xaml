<Window x:Class="simulador_algoritmos_so.FifoPaginasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FIFO — Reemplazo de Páginas" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#E0E0E0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="← Regresar" Grid.Column="0"
            Margin="5" Padding="10,5"
            Click="BtnRegresar_Click"/>
            <TextBlock Text="FIFO — Reemplazo de Páginas"
               Grid.Column="1"
               FontSize="16" FontWeight="Bold"
               VerticalAlignment="Center" Margin="10,0"/>
        </Grid>

        <!-- Controles superiores -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Número de marcos (frames):" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtFrames" Width="50" Margin="5" Text="3"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Cadena de referencias:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtReferencias" Width="300" Margin="5" Text=""/>
                <TextBlock Text="(ej: 1 2 3 4 1 2 5)" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="11"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Llenado Manual" Click="BtnManual_Click" Margin="5" Padding="10,2"/>
                <Button Content="Llenado Aleatorio" Click="BtnAleatorio_Click" Margin="5" Padding="10,2"/>
            </StackPanel>
        </StackPanel>

        <!-- Tabla de estados -->
        <DataGrid x:Name="dgPaginas" Grid.Row="2" Margin="5"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Referencia" Binding="{Binding Referencia}" Width="80"/>
                <DataGridTextColumn Header="Frames" Binding="{Binding EstadoFrames}" Width="*"/>
                <DataGridTextColumn Header="Resultado" Binding="{Binding Resultado}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Resumen -->
        <GroupBox Header="Resumen" Grid.Row="3" Margin="5">
            <StackPanel Margin="10">
                <TextBlock x:Name="txtFallos" FontSize="14" Margin="0,5"/>
                <TextBlock x:Name="txtAciertos" FontSize="14" Margin="0,5"/>
                <TextBlock x:Name="txtTasa" FontSize="14" Margin="0,5"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>

<Window x:Class="simulador_algoritmos_so.ProcesosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Planificación de Procesos" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Grid Grid.Row="0" Background="#E0E0E0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="← Regresar" Grid.Column="0"
                    Margin="5" Padding="10,5"
                    Click="BtnRegresar_Click"/>
            <TextBlock Text="Planificación de Procesos"
                       Grid.Column="1" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="10,0"/>
        </Grid>

        <!-- Controles -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Algoritmo:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="cmbAlgoritmo" Width="150" Margin="5" SelectedIndex="0">
                <ComboBoxItem Content="FIFO"/>
                <ComboBoxItem Content="SJF"/>
            </ComboBox>
            <TextBlock Text="Número de procesos:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="txtCantidad" Width="50" Margin="5" Text="5"/>
            <Button Content="Llenado Manual" Click="BtnManual_Click" Margin="5" Padding="10,2"/>
            <Button Content="Llenado Aleatorio" Click="BtnAleatorio_Click" Margin="5" Padding="10,2"/>
            <Button Content="Recalcular" Click="BtnRecalcular_Click" Margin="5" Padding="10,2"/>
        </StackPanel>

        <!-- Contenido principal: tabla + gantt lado a lado -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tabla -->
            <DataGrid x:Name="dgProcesos" Grid.Column="0" Margin="5"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      RowBackground="White"
                      AlternatingRowBackground="White"
                      ColumnHeaderHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Proceso" Binding="{Binding Nombre}" Width="65"/>
                    <DataGridTextColumn Header="Llegada" Binding="{Binding Llegada}" Width="60"/>
                    <DataGridTextColumn Header="t" Binding="{Binding t}" Width="40"/>
                    <DataGridTextColumn Header="Prioridad" Binding="{Binding Prioridad}" Width="65"/>
                    <DataGridTextColumn Header="Inicio" Binding="{Binding Inicio}" Width="50"/>
                    <DataGridTextColumn Header="Fin" Binding="{Binding Fin}" Width="40"/>
                    <DataGridTextColumn Header="T" Binding="{Binding T}" Width="40"/>
                    <DataGridTextColumn Header="E" Binding="{Binding E}" Width="40"/>
                    <DataGridTextColumn Header="P" Binding="{Binding P}" Width="40"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <!-- Gantt cuadrícula -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto" Margin="5">
                <ContentControl x:Name="icGantt"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

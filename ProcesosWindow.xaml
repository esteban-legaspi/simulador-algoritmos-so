<Window x:Class="simulador_algoritmos_so.ProcesosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Planificación de Procesos" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <!-- estadísticas -->
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Grid Grid.Row="0" Background="#E0E0E0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="← Regresar" Grid.Column="0" Margin="5" Padding="10,5" Click="BtnRegresar_Click"/>
            <TextBlock Text="Planificación de Procesos" Grid.Column="1"
                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
        </Grid>

        <!-- Controles -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Algoritmo:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="cmbAlgoritmo" Width="150" Margin="5" SelectedIndex="0">
                <ComboBoxItem Content="FIFO"/>
                <ComboBoxItem Content="Round Robin"/>
                <ComboBoxItem Content="Prioridad"/>
                <ComboBoxItem Content="SRTF"/>
                <ComboBoxItem Content="SJF"/>
            </ComboBox>
            <!-- Quantum (solo relevante para Round Robin) -->
            <TextBlock Text="Quantum:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="txtQuantum" Width="40" Margin="5" Text="2"/>
            <TextBlock Text="Núm. procesos:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="txtCantidad" Width="50" Margin="5" Text="5"/>
            <Button Content="Llenado Manual"   Click="BtnManual_Click"    Margin="5" Padding="10,2"/>
            <Button Content="Llenado Aleatorio" Click="BtnAleatorio_Click" Margin="5" Padding="10,2"/>
            <Button Content="Recalcular"        Click="BtnRecalcular_Click" Margin="5" Padding="10,2"/>
        </StackPanel>

        <!-- Tabla + Gantt -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="dgProcesos" Grid.Column="0" Margin="5"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      RowBackground="White" AlternatingRowBackground="White" ColumnHeaderHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Proceso"  Binding="{Binding Nombre}"    Width="65"/>
                    <DataGridTextColumn Header="Llegada"  Binding="{Binding Llegada}"   Width="60"/>
                    <DataGridTextColumn Header="t"        Binding="{Binding t}"         Width="40"/>
                    <DataGridTextColumn Header="Prior."   Binding="{Binding Prioridad}" Width="55"/>
                    <DataGridTextColumn Header="Inicio"   Binding="{Binding Inicio}"    Width="50"/>
                    <DataGridTextColumn Header="Fin"      Binding="{Binding Fin}"       Width="40"/>
                    <DataGridTextColumn Header="T"        Binding="{Binding T}"         Width="40"/>
                    <DataGridTextColumn Header="E"        Binding="{Binding E}"         Width="40"/>
                    <DataGridTextColumn Header="P"        Binding="{Binding P}"         Width="40"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto" Margin="5">
                <ContentControl x:Name="icGantt"/>
            </ScrollViewer>
        </Grid>

        <!-- Estadísticas -->
        <Border Grid.Row="3" Background="#E8E8E8" BorderBrush="#CCCCCC"
                BorderThickness="1" Margin="0,5,0,0" Padding="10,6">
            <TextBlock x:Name="txtStats" FontSize="13" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
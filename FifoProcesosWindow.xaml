<Window x:Class="simulador_algoritmos_so.FifoProcesosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FIFO — Planificación de Procesos" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Encabezado con botón regresar -->
        <Grid Grid.Row="0" Background="#E0E0E0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="← Regresar" Grid.Column="0"
            Margin="5" Padding="10,5"
            Click="BtnRegresar_Click"/>
            <TextBlock Text="FIFO — Planificación de Procesos"
               Grid.Column="1"
               FontSize="16" FontWeight="Bold"
               VerticalAlignment="Center" Margin="10,0"/>
        </Grid>

        <!-- Controles superiores -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Número de procesos:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="txtCantidad" Width="50" Margin="5" Text="5"/>
            <Button Content="Llenado Manual" Click="BtnManual_Click" Margin="5" Padding="10,2"/>
            <Button Content="Llenado Aleatorio" Click="BtnAleatorio_Click" Margin="5" Padding="10,2"/>
        </StackPanel>

        <!-- Tabla de resultados -->
        <DataGrid x:Name="dgFifo" Grid.Row="2" Margin="5"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Proceso" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Ráfaga" Binding="{Binding Rafaga}" Width="*"/>
                <DataGridTextColumn Header="T. Espera" Binding="{Binding TiempoEspera}" Width="*"/>
                <DataGridTextColumn Header="T. Retorno" Binding="{Binding TiempoRetorno}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Gráfica de Gantt -->
        <GroupBox Header="Gráfica de Gantt" Grid.Row="3" Margin="5">
            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icGantt">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>

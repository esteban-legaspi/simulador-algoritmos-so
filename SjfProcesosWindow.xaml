<Window x:Class="simulador_algoritmos_so.SjfProcesosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SJF — Trabajo más Corto Primero" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Número de procesos:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="txtCantidad" Width="50" Margin="5" Text="5"/>
            <Button Content="Llenado Manual" Click="BtnManual_Click" Margin="5" Padding="10,2"/>
            <Button Content="Llenado Aleatorio" Click="BtnAleatorio_Click" Margin="5" Padding="10,2"/>
        </StackPanel>

        <DataGrid x:Name="dgSjf" Grid.Row="1" Margin="5"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Proceso" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Ráfaga" Binding="{Binding Rafaga}" Width="*"/>
                <DataGridTextColumn Header="Orden Ejecución" Binding="{Binding OrdenEjecucion}" Width="*"/>
                <DataGridTextColumn Header="T. Espera" Binding="{Binding TiempoEspera}" Width="*"/>
                <DataGridTextColumn Header="T. Retorno" Binding="{Binding TiempoRetorno}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Header="Gráfica de Gantt" Grid.Row="2" Margin="5">
            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icGantt">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>

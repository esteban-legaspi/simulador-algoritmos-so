<Window x:Class="simulador_algoritmos_so.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Simulador de Algoritmos SO" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F4F8">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Simulador de Algoritmos SO"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <Button Content="Procesos"
                    x:Name="BtnProcesosClick"
                    Height="50" Margin="0,8"
                    FontSize="14"
                    Click="ProcesosClick"/>

            <Button Content="FIFO — Reemplazo de Páginas"
                    x:Name="btnFifoPaginas"
                    Height="50" Margin="0,8"
                    FontSize="14"
                    Click="BtnFifoPaginas_Click"/>
        </StackPanel>
    </Grid>
</Window>
